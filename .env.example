# ── Security ───────────────────────────────────────────────────────────────────
# Fernet key used to encrypt users' BYOK provider keys at rest.
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_ENCRYPTION_KEY=

# ── BYOK mode ──────────────────────────────────────────────────────────────────
# false → server falls back to the keys below when a user has no key of their own
# true  → every AI feature requires the user to add their own key (402 otherwise)
BYOK_REQUIRED=false

# ── Server-side LLM fallback (only used while BYOK_REQUIRED=false) ─────────────
# Default routing is grok, so XAI_API_KEY is the one that actually gets used.
# DEEPSEEK_API_KEY is only hit if api/llm_config.json routes a task to deepseek.
XAI_API_KEY=
DEEPSEEK_API_KEY=
# Optional model overrides (sensible defaults applied if omitted):
# XAI_MODEL=grok-3
# DEEPSEEK_MODEL=deepseek-chat

# ── Database ───────────────────────────────────────────────────────────────────
# Omit for local dev — defaults to SQLite (wand.db in the project root).
# For PostgreSQL: postgresql://user:password@host:5432/dbname
# DATABASE_URL=

# ── File storage ───────────────────────────────────────────────────────────────
# Omit for local dev — files are stored in api/uploads/.
# For Supabase Storage (production):
# SUPABASE_URL=https://[PROJECT].supabase.co
# SUPABASE_SERVICE_KEY=

# ── CORS ───────────────────────────────────────────────────────────────────────
# Defaults to http://localhost:3000 when omitted (local dev).
# Set explicitly in any deployed environment.
# ALLOWED_ORIGINS=http://localhost:3000

# ── Google Custom Search — optional, powers reachout contact discovery ─────────
# Without these, reachout falls back to DuckDuckGo scraping.
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=

# ── Debug (leave unset in production) ──────────────────────────────────────────
# LLM_DEBUG_CAPTURE=1                 # dump raw LLM request/response to disk
# LLM_DEBUG_LOG=llm_debug.jsonl       # where LLM_DEBUG_CAPTURE writes
# LLM_MAX_INPUT_CHARS=400000          # truncation budget for LLM inputs
# REACHOUT_SEARCH_PROVIDERS=ddgs,duckduckgo_html,google_cse  # search order override
